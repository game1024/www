---
import { getCollection } from 'astro:content';
import { ScrollArea } from '@/components/ui/scroll-area';
import { Icon } from 'astro-icon/components';
import Marquee from './Marquee.astro';

export interface Props {
  /** 当前文章 slug，用于高亮 */
  currentSlug?: string;
  /** 自定义类名 */
  class?: string;
}

const {
  currentSlug,
  class: className,
} = Astro.props;

// 获取所有文章并按日期排序
const allPosts = await getCollection('posts');
const recentPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.createdAt.getTime() - a.data.createdAt.getTime())
  .slice(0, 30);
---

<aside
  class:list={[
    "flex flex-col w-80 h-full bg-background border-r border-border overflow-y-auto",
    className,
  ]}
>
  <ScrollArea client:load className="h-full">
    <div class="p-6">
      <!-- 标题 -->
      <div class="mb-4">
        <h2 class="text-xl font-bold text-foreground mb-1">近期文章</h2>
        <p class="text-sm text-muted-foreground">Recent Posts</p>
      </div>

      <!-- 文章列表 -->
      <div class="space-y-2.5">
        {recentPosts.map((post) => {
          const isActive = currentSlug === post.slug;
          return (
            <a
              href={`/posts/${post.slug}`}
              class:list={[
                "block p-3 rounded-lg border transition-all duration-200 group",
                isActive
                  ? "bg-primary/10 border-primary/30 text-primary shadow-sm"
                  : "border-border"
              ]}
            >
              <div class="flex items-center justify-between mb-1.5">
                {post.data.category && (
                  <span class:list={[
                    "inline-flex items-center gap-1 rounded-md px-1.5 py-0.5 text-[10px] font-medium",
                    isActive
                      ? "bg-primary/15 text-primary"
                      : "bg-secondary text-secondary-foreground"
                  ]}>
                    <Icon name="ri:stack-line" class="size-3" />
                    {post.data.category}
                  </span>
                )}
                <time
                  datetime={post.data.createdAt.toISOString()}
                  class:list={[
                    "text-[10px] text-muted-foreground",
                    !post.data.category && "ml-auto"
                  ]}
                >
                  {`${post.data.createdAt.getFullYear()}年${String(post.data.createdAt.getMonth() + 1).padStart(2, '0')}月${String(post.data.createdAt.getDate()).padStart(2, '0')}日`}
                </time>
              </div>
              <div class="overflow-hidden">
                <Marquee
                  text={post.data.title}
                  tag="h3"
                  class:list={[
                    "text-sm font-medium",
                    isActive ? "text-primary" : "text-foreground"
                  ]}
                  duration={3}
                />
              </div>
            </a>
          );
        })}
      </div>

      <!-- 查看更多 -->
      <a
        href="/archive"
        class="mt-4 text-sm text-center text-primary hover:text-primary/80 transition-colors py-2 block"
      >
        查看全部文章 →
      </a>
    </div>
  </ScrollArea>
</aside>

<style is:global>
  a.group:hover marquee-text h3 {
    text-decoration: underline;
    font-weight: 700;
  }
</style>
